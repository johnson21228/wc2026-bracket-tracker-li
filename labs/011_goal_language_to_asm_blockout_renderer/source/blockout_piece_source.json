{
  "kind": "blockout_piece_source",
  "version": 2,
  "constraints": {
    "minCubeCount": 1,
    "maxCubeCount": 4,
    "maxExtentAnyAxis": 3,
    "forbidFull3x3Footprint": true,
    "requireFaceContiguous": true,
    "requireNormalizedRotations": true,
    "pitFootprint": {
      "width": 5,
      "height": 5
    }
  },
  "units": {
    "cell": "one pit cube",
    "coordinates": "integer local piece coordinates [x,y,z]",
    "fallAxis": "z",
    "pitPlane": "x/y",
    "originRule": "rotation definitions are normalized so min x/y/z is 0"
  },
  "rendering": {
    "activePieceStyle": {
      "bitmap": "wireframe",
      "color": "white",
      "drawPriority": "after_pit_and_locked_blocks",
      "c64HiResColorRule": "any touched 8x8 cell may become white while the active piece is present"
    },
    "lockedPieceStyle": {
      "bitmap": "future_colored_fill_or_colored_wire",
      "drawPriority": "after_pit_before_active_piece",
      "status": "not_implemented_in_pit_only_base"
    },
    "outlineRule": {
      "source": "occupied cube set",
      "algorithm": [
        "find exposed faces by checking missing face-neighbor cubes",
        "collect face boundary edges",
        "deduplicate shared exposed edges",
        "project only exposed outline edges",
        "do not draw internal cube-to-cube seams"
      ]
    },
    "dirtyContract": {
      "activeMove": [
        "restore previous active dirty bitmap bytes from static layer",
        "restore previous active dirty screen/color cells from static layer",
        "draw current active wireframe records",
        "remember current dirty bitmap byte offsets and touched color cells"
      ],
      "dirtyKeys": [
        "bitmapByteOffset",
        "screenCellOffset",
        "colorCellOffset"
      ],
      "staticLayer": [
        "pit",
        "locked_blocks_when_landed"
      ],
      "activeLayer": [
        "active_piece_wireframe"
      ]
    }
  },
