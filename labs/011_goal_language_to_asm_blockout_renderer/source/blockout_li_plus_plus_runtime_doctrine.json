{
  "schemaVersion": 1,
  "labId": "011_goal_language_to_asm_blockout_renderer",
  "name": "LI++ lean runtime doctrine",
  "doctrine": {
    "intelligenceLives": "upstream_li_source_generator_verifier",
    "runtimeRole": "lean_deterministic_executor",
    "payloadRole": "contract_between_generator_and_runtime",
    "screenRole": "proof_surface"
  },
  "corePhrases": [
    "The intelligence lives upstream.",
    "The runtime stays lean.",
    "The payload is the contract.",
    "The screen is the proof.",
    "The C64 does not reason about Blockout. The Workbench reasons Blockout into payloads. The C64 executes the payloads."
  ],
  "runtimeAllowedResponsibilities": [
    "display_setup",
    "pit_static_render_or_restore",
    "current_piece_payload_load_or_copy",
    "pose_record_selection",
    "previous_dirty_restore",
    "bitmap_byte_mask_draw_execution",
    "candidate_occupied_cell_collision_check",
    "active_cube_lock_into_occupied_cells"
  ],
  "runtimeForbiddenResponsibilities": [
    "3d_rotation_matrix_math",
    "projection_math",
    "active_piece_line_rasterization",
    "bitmap_mask_discovery",
    "all_shapes_resident_pose_table_storage",
    "semantic_shape_interpretation"
  ],
  "residentMemoryDoctrine": {
    "rule": "resident_memory_must_earn_its_rent",
    "allowedReasons": [
      "needed_every_frame",
      "needed_for_immediate_input_response",
      "needed_as_current_static_truth",
      "impossible_or_too_slow_to_reload_for_current_interaction"
    ],
    "prefer": [
      "one_active_payload_slot",
      "small_indices_and_pointers",
      "cell_occupancy_over_locked_piece_objects",
      "generated_records_over_runtime_derivation",
      "file_io_as_memory_strategy"
    ]
  },
  "liPlusPlusMeaning": {
    "notJustProse": true,
    "components": [
      "doctrine_text",
      "structured_source_contract",
      "verifier",
      "runtime_boundary",
      "generator_responsibility_list",
      "memory_budget_rule",
      "source_to_payload_rule"
    ]
  },
  "testableConsequences": [
    "reject_all_starter_piece_payloads_resident_by_default",
    "reject_runtime_projection_for_active_pieces",
    "reject_locked_blocks_as_locked_piece_objects",
    "reject_sprites_as_primary_active_piece_renderer",
    "reject_removal_of_one_current_payload_memory_boundary",
    "reject_bypass_of_source_verifier_payload_discipline"
  ]
}
